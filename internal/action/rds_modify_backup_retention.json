{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://casper.dev/schemas/rds_modify_backup_retention.schema.json",
  "title": "RDSModifyBackupRetentionProposal",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "db_instance_identifier",
    "region",
    "current_retention_days",
    "target_retention_days",
    "apply_immediately",
    "reasoning"
  ],
  "properties": {
    "db_instance_identifier": {
      "type": "string",
      "minLength": 1,
      "maxLength": 63,
      "pattern": "^[a-zA-Z][a-zA-Z0-9-]*$"
    },
    "region": {
      "type": "string",
      "pattern": "^[a-z]{2}-[a-z]+-[0-9]+$"
    },
    "current_retention_days": {
      "type": "integer",
      "minimum": 0,
      "maximum": 35
    },
    "target_retention_days": {
      "type": "integer",
      "minimum": 0,
      "maximum": 35
    },
    "apply_immediately": {
      "type": "boolean",
      "const": true
    },
    "reasoning": {
      "type": "string",
      "minLength": 1
    }
  }
}
